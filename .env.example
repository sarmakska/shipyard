# Local SQLite database path. Defaults to in-memory if unset.
SHIPYARD_DB_PATH=shipyard.db

# Billing provider: "fake" (default) or "stripe".
BILLING_PROVIDER=fake

# Stripe configuration. Only required when BILLING_PROVIDER=stripe.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_SCALE=price_scale_placeholder
